# Copy this file to .env and fill in your Supabase project details.
# Without these values the app runs fine but global stats will be disabled.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google AdSense publisher ID (e.g. ca-pub-1234567890123456).
# Used for rewarded ads (extra-chance after game over). Replace the placeholder
# in index.html with this value. Without it, the app falls back to a mock ad.
VITE_ADSENSE_CLIENT_ID=ca-pub-3897105282692854

# Set to "true" only after AdSense approval + rewarded ad unit is live.
# While false, the "extra chance" button skips the ad and grants the reward
# immediately — needed because adBreak() never calls back without an active
# ad unit, which would hang the UI.
VITE_ADS_ENABLED=false
